---
interface Props {
  name: string;
  description: string | null;
  url: string;
  homepage: string | null;
  language: string | null;
  stars: number;
  updatedAt: string;
}

const { name, description, url, homepage, language, stars, updatedAt } = Astro.props;

const updated = new Date(updatedAt).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---
<div class="project-card">
  <h3><a href={url} target="_blank" rel="noopener" class="project-link">{name}</a></h3>
  {description && <p class="project-desc">{description}</p>}
  <div class="project-meta">
    {language && <span class="project-lang">{language}</span>}
    {stars > 0 && <span class="project-stars">{stars} stars</span>}
    <span class="project-updated">Updated {updated}</span>
    {homepage && (
      <a href={homepage} target="_blank" rel="noopener" class="project-website">Website</a>
    )}
  </div>
</div>

<style>
  .project-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-lg);
    transition: border-color 0.2s, transform 0.2s;
  }
  .project-card:hover {
    border-color: var(--electric-teal);
    transform: translateY(-2px);
  }
  h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }
  .project-link {
    color: var(--color-text);
    text-decoration: none;
  }
  .project-link:hover {
    color: var(--electric-teal);
    text-decoration: none;
  }
  .project-desc {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-bottom: var(--space-md);
  }
  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
  .project-website {
    color: var(--electric-teal);
    margin-left: auto;
  }
  .project-website:hover {
    text-decoration: none;
  }
</style>
